@{
    var product = ViewData.Model as StockifyPlus.Models.Product;
    ViewBag.Title = "Ürünü Sil";
}

<div class="row">
    <div class="col-md-6 offset-md-3">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0">
                    <i class="fas fa-trash"></i> Ürünü Sil
                </h5>
            </div>
            <div class="card-body">
                <div class="alert alert-warning">
                    <i class="fas fa-exclamation-triangle"></i> 
                    <strong>Dikkat!</strong> Bu işlem geri alınamaz. Ürün pasif duruma geçecektir.
                </div>
                
                <p>Şu ürünün silinmesini onaylıyor musunuz?</p>
                
                <div class="card bg-light mb-3">
                    <div class="card-body">
                        <p class="mb-1"><strong>SKU:</strong> @product.SKU</p>
                        <p class="mb-1"><strong>Adı:</strong> @product.Name</p>
                        <p class="mb-1"><strong>Kategori:</strong> @product.Category?.Name</p>
                        <p class="mb-1"><strong>Mevcut Stok:</strong> @product.StockQuantity</p>
                        <p class="mb-0"><strong>Fiyat:</strong> @product.Price.ToString("C")</p>
                    </div>
                </div>
                
                <form method="post" asp-action="Delete">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@product.Id">
                    
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger btn-custom">
                            <i class="fas fa-trash"></i> Evet, Sil
                        </button>
                        <a href="@Url.Action("Index", "Product")" class="btn btn-secondary btn-custom">
                            <i class="fas fa-times"></i> İptal
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
