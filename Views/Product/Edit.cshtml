@{
    var product = ViewData.Model as StockifyPlus.Models.Product;
    var categories = ViewBag.Categories as List<StockifyPlus.Models.Category> ?? new List<StockifyPlus.Models.Category>();
    var trCulture = new System.Globalization.CultureInfo("tr-TR");
    ViewBag.Title = "Ürün Düzenle";
}

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0">
                    <i class="fas fa-edit"></i> Ürün Düzenle
                </h5>
            </div>
            <div class="card-body">
                <form method="post" asp-action="Edit">
                    @Html.AntiForgeryToken()
                    
                    <input type="hidden" name="id" value="@product.Id">
                    
                    <div class="mb-3">
                        <label class="form-label">Ürün ID</label>
                        <input type="text" class="form-control" value="@product.Id" disabled>
                    </div>
                    
                    <div class="mb-3">
                        <label for="categoryId" class="form-label">Kategori <span class="text-danger">*</span></label>
                        <select class="form-select" id="categoryId" name="categoryId" required>
                            @foreach (var category in categories)
                            {
                                <option value="@category.Id" selected="@(category.Id == product.CategoryId)">@category.Name</option>
                            }
                        </select>
                    </div>
                    
                    <div class="mb-3">
                        <label for="name" class="form-label">Ürün Adı <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="name" name="name" value="@product.Name" required>
                    </div>
                    
                    <div class="mb-3">
                        <label for="sku" class="form-label">SKU <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="sku" name="sku" value="@product.SKU" required>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="price" class="form-label">Fiyat (₺)</label>
                            <input type="text" class="form-control" id="price" name="price"
                                value="@product.Price.ToString("N2", trCulture)" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="criticalLevel" class="form-label">Kritik Stok Seviyesi</label>
                            <input type="number" class="form-control" id="criticalLevel" name="criticalLevel" 
                                   value="@product.CriticalStockLevel" min="0" required>
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label for="description" class="form-label">Açıklama</label>
                        <textarea class="form-control" id="description" name="description" rows="3">@product.Description</textarea>
                    </div>
                    
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            @foreach (var modelState in ViewData.ModelState.Values)
                            {
                                @foreach (var error in modelState.Errors)
                                {
                                    <div>@error.ErrorMessage</div>
                                }
                            }
                        </div>
                    }
                    
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning btn-custom">
                            <i class="fas fa-save"></i> Güncelle
                        </button>
                        <a href="@Url.Action("Index", "Product")" class="btn btn-secondary btn-custom">
                            <i class="fas fa-times"></i> İptal
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-header bg-info text-white">
                <h6 class="mb-0">
                    <i class="fas fa-info-circle"></i> Ürün Bilgileri
                </h6>
            </div>
            <div class="card-body small">
                <p class="mb-2"><strong>Mevcut Stok:</strong> <span class="badge bg-primary">@product.StockQuantity</span></p>
                <p class="mb-2"><strong>Durum:</strong> 
                    @if (product.IsActive)
                    {
                        <span class="badge bg-success">Aktif</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Pasif</span>
                    }
                </p>
                <p class="mb-0"><strong>Oluşturma Tarihi:</strong> @product.CreatedDate.ToString("dd.MM.yyyy")</p>
            </div>
        </div>
    </div>
</div>
