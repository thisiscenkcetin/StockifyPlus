@model StockifyPlus.Models.Product
@{
    ViewBag.Title = "Ürün Barkodu";
}

<div class="row">
    <div class="col-md-8 offset-md-2">
        <div class="card">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="fas fa-barcode"></i> Barkod Sayfası
                </h5>
                <span class="badge bg-light text-dark">@Model.SKU</span>
            </div>
            <div class="card-body text-center">
                <h4 class="mb-2">@Model.Name</h4>
                <p class="text-muted mb-4">Kategori: @Model.Category?.Name</p>

                <div class="border rounded p-4 bg-white mb-3" id="barcodePrintArea">
                    <svg id="skuBarcode"></svg>
                    <div class="mt-2 fw-bold">@Model.SKU</div>
                </div>

                <div class="d-flex gap-2 justify-content-center">
                    <button type="button" class="btn btn-primary btn-custom" id="printBarcodeBtn">
                        <i class="fas fa-print"></i> Barkodu Yazdır
                    </button>
                    <a href="@Url.Action("Index", "Product")" class="btn btn-secondary btn-custom">
                        <i class="fas fa-arrow-left"></i> Geri Dön
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.6/dist/JsBarcode.all.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const sku = '@Model.SKU';
            const barcodeElement = document.getElementById('skuBarcode');
            const printButton = document.getElementById('printBarcodeBtn');

            if (barcodeElement) {
                JsBarcode(barcodeElement, sku, {
                    format: 'CODE128',
                    lineColor: '#111',
                    width: 2,
                    height: 90,
                    displayValue: false,
                    margin: 10
                });
            }

            if (printButton) {
                printButton.addEventListener('click', function () {
                    window.print();
                });
            }
        });
    </script>
}