@using StockifyPlus.Services.Interfaces
@inject INotificationSettingService NotificationSettingService
@{
    var isPushEnabled = true;
    var isSignedIn = !string.IsNullOrWhiteSpace(Context.Session.GetString("UserId"));
    try
    {
        isPushEnabled = await NotificationSettingService.IsPushEnabledAsync();
    }
    catch
    {
        isPushEnabled = true;
    }
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - StockifyPlus</title>
    
    <!-- Ana stil kutuphanesi -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Ikon seti -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    
    <!-- Grafik kutuphanesi -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary: #1e88e5;
            --accent: #2196F3;
            --light-bg: #f5f5f7;
            --glass: rgba(255, 255, 255, 0.8);
            --glass-border: rgba(255, 255, 255, 0.3);
            --shadow: 0 8px 32px rgba(31, 38, 135, 0.15);
            --soft-shadow: 0 2px 16px rgba(0, 0, 0, 0.08);
        }

        html, body {
            width: 100%;
            height: 100%;
            overflow: hidden;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #e8eef5 0%, #f0f4f8 100%);
            display: flex;
            flex-direction: column;
            color: #222;
        }

        .main-container {
            display: flex;
            flex: 1;
            overflow: hidden;
            gap: 1rem;
            padding: 1.5rem;
        }

        .sidebar {
            width: 20%;
            display: flex;
            flex-direction: column;
            background: var(--glass);
            backdrop-filter: blur(10px);
            border: 1px solid var(--glass-border);
            border-radius: 1.5rem;
            padding: 1.5rem;
            box-shadow: var(--soft-shadow);
            align-items: center;
            gap: 2rem;
        }

        .traffic-lights {
            display: flex;
            gap: 0.5rem;
            align-self: flex-start;
            margin-bottom: 1rem;
        }

        .traffic-light {
            width: 14px;
            height: 14px;
            border-radius: 50%;
            cursor: pointer;
            transition: transform 0.2s;
        }

        .traffic-light:hover {
            transform: scale(1.15);
        }

        .red { background: #ff5f56; }
        .yellow { background: #ffbd2e; }
        .green { background: #27c93f; }

        .logo {
            text-align: center;
            margin-bottom: 1rem;
        }

        .logo-icon {
            font-size: 2.5rem;
            color: var(--primary);
            margin-bottom: 0.5rem;
        }

        .logo-text {
            font-size: 0.85rem;
            font-weight: 600;
            color: #666;
            letter-spacing: 0.5px;
        }

        .sidebar-nav {
            display: flex;
            flex-direction: column;
            gap: 1rem;
            flex: 1;
            width: 100%;
        }

        .nav-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.75rem;
            padding: 1.25rem;
            border-radius: 1.2rem;
            cursor: pointer;
            transition: all 0.3s;
            text-decoration: none;
            color: #666;
            background: rgba(30, 136, 229, 0.01);
        }

        .nav-item:hover {
            background: rgba(30, 136, 229, 0.1);
            color: var(--primary);
            transform: scale(1.05);
        }

        .nav-item.active {
            background: linear-gradient(135deg, var(--primary), var(--accent));
            color: white;
        }

        .nav-icon {
            font-size: 2rem;
        }

        .nav-label {
            font-size: 0.8rem;
            font-weight: 500;
            text-align: center;
        }

        .user-card {
            width: 100%;
            background: var(--glass);
            backdrop-filter: blur(10px);
            border: 1px solid var(--glass-border);
            border-radius: 1rem;
            padding: 1rem;
            text-align: center;
            margin-top: auto;
        }

        .user-avatar {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.5rem;
            margin: 0 auto 0.75rem;
        }

        .user-name {
            font-size: 0.85rem;
            font-weight: 600;
            color: #222;
        }

        .user-role {
            font-size: 0.7rem;
            color: #999;
            margin-top: 0.25rem;
        }

        .center-panel {
            flex: 1.1;
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
            overflow-y: auto;
            padding-right: 0.5rem;
        }

        .center-panel::-webkit-scrollbar {
            width: 6px;
        }

        .center-panel::-webkit-scrollbar-track {
            background: transparent;
        }

        .center-panel::-webkit-scrollbar-thumb {
            background: rgba(0, 0, 0, 0.1);
            border-radius: 10px;
        }

        .kpi-row {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1rem;
        }

        .kpi-card {
            background: var(--glass);
            backdrop-filter: blur(10px);
            border: 1px solid var(--glass-border);
            border-radius: 1.5rem;
            padding: 1.5rem;
            box-shadow: var(--soft-shadow);
            transition: all 0.3s;
            cursor: pointer;
        }

        .kpi-card:hover {
            transform: translateY(-4px);
            background: rgba(255, 255, 255, 0.95);
            box-shadow: 0 12px 40px rgba(31, 38, 135, 0.2);
        }

        .kpi-icon {
            font-size: 2.5rem;
            margin-bottom: 0.75rem;
        }

        .kpi-card:nth-child(1) .kpi-icon { color: #FF6B6B; }
        .kpi-card:nth-child(2) .kpi-icon { color: #FFA500; }
        .kpi-card:nth-child(3) .kpi-icon { color: #4CAF50; }

        .kpi-label {
            font-size: 0.85rem;
            color: #999;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 0.5rem;
        }

        .kpi-value {
            font-size: 2.5rem;
            font-weight: 700;
            color: #222;
            margin-bottom: 0.5rem;
        }

        .kpi-subtext {
            font-size: 0.75rem;
            color: #ccc;
        }

        .chart-container {
            background: var(--glass);
            backdrop-filter: blur(10px);
            border: 1px solid var(--glass-border);
            border-radius: 1.5rem;
            padding: 1.5rem;
            box-shadow: var(--soft-shadow);
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .chart-title {
            font-size: 1rem;
            font-weight: 600;
            color: #222;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .chart-title i {
            color: var(--primary);
        }

        canvas {
            max-height: 300px;
        }

        .right-panel {
            width: 25%;
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .quick-actions {
            background: var(--glass);
            backdrop-filter: blur(10px);
            border: 1px solid var(--glass-border);
            border-radius: 1.5rem;
            padding: 1.5rem;
            box-shadow: var(--soft-shadow);
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .action-btn {
            padding: 1rem 1.5rem;
            border: none;
            border-radius: 1rem;
            font-weight: 600;
            font-size: 0.95rem;
            cursor: pointer;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.75rem;
            text-decoration: none;
            color: white;
        }

        .action-btn-primary {
            background: linear-gradient(135deg, var(--primary), var(--accent));
            box-shadow: 0 4px 16px rgba(30, 136, 229, 0.3);
        }

        .action-btn-primary:hover {
            transform: scale(1.02);
            box-shadow: 0 6px 24px rgba(30, 136, 229, 0.4);
            color: white;
            text-decoration: none;
        }

        .action-btn i {
            font-size: 1.25rem;
        }

        .activity-log {
            background: var(--glass);
            backdrop-filter: blur(10px);
            border: 1px solid var(--glass-border);
            border-radius: 1.5rem;
            padding: 1.5rem;
            box-shadow: var(--soft-shadow);
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .activity-title {
            font-size: 1rem;
            font-weight: 600;
            color: #222;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .activity-title i {
            color: var(--primary);
        }

        .activity-list {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
            overflow-y: auto;
            flex: 1;
        }

        .activity-list::-webkit-scrollbar {
            width: 4px;
        }

        .activity-list::-webkit-scrollbar-track {
            background: transparent;
        }

        .activity-list::-webkit-scrollbar-thumb {
            background: rgba(0, 0, 0, 0.1);
            border-radius: 10px;
        }

        .activity-item {
            padding: 0.75rem;
            background: rgba(30, 136, 229, 0.05);
            border-left: 3px solid var(--primary);
            border-radius: 0.5rem;
            font-size: 0.85rem;
            color: #666;
        }

        .activity-time {
            font-size: 0.7rem;
            color: #999;
            margin-top: 0.25rem;
        }

        @@media (max-width: 1400px) {
            .kpi-row {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @@media (max-width: 1024px) {
            .main-container {
                flex-direction: column;
                padding: 1rem;
                gap: 1rem;
            }

            .sidebar {
                width: 100%;
                flex-direction: row;
                align-items: center;
            }

            .sidebar-nav {
                flex-direction: row;
                flex: 1;
                justify-content: center;
            }

            .center-panel {
                flex: none;
            }

            .right-panel {
                width: 100%;
                flex-direction: row;
            }
        }
    </style>
</head>
<body>
    <form id="stockaiAntiForgeryForm" style="display: none;">
        @Html.AntiForgeryToken()
    </form>

    <div class="main-container">
        <!-- Sol menu -->
        <div class="sidebar">
            <div class="traffic-lights">
                <div class="traffic-light red"></div>
                <div class="traffic-light yellow"></div>
                <div class="traffic-light green"></div>
            </div>

            <div class="logo">
                <div class="logo-icon">
                    <img src="~/images/stockify-logo.png" alt="StockifyPlus" style="height: 40px; width: auto; object-fit: contain;">
                </div>
                <div class="logo-text">Akıllı Depo Sistemi</div>
            </div>

            <nav class="sidebar-nav">
                <a href="@Url.Action("Index", "Home")" class="nav-item @(ViewContext.RouteData.Values["Controller"].ToString() == "Home" ? "active" : "")">
                    <div class="nav-icon"><i class="fas fa-chart-line"></i></div>
                    <div class="nav-label">Dashboard</div>
                </a>

                <a href="@Url.Action("Index", "Product")" class="nav-item @(ViewContext.RouteData.Values["Controller"].ToString() == "Product" ? "active" : "")">
                    <div class="nav-icon"><i class="fas fa-box"></i></div>
                    <div class="nav-label">&Uuml;r&uuml;nler</div>
                </a>

                <a href="@Url.Action("Index", "Category")" class="nav-item @(ViewContext.RouteData.Values["Controller"].ToString() == "Category" ? "active" : "")">
                    <div class="nav-icon"><i class="fas fa-layer-group"></i></div>
                    <div class="nav-label">Kategoriler</div>
                </a>

                <a href="@Url.Action("Index", "StockMovement")" class="nav-item @(ViewContext.RouteData.Values["Controller"].ToString() == "StockMovement" ? "active" : "")">
                    <div class="nav-icon"><i class="fas fa-exchange-alt"></i></div>
                    <div class="nav-label">Hareketler</div>
                </a>
            </nav>

            @if (Context.User.Identity.IsAuthenticated)
            {
                <div class="user-card">
                    <div class="user-avatar">
                        <i class="fas fa-user"></i>
                    </div>
                    <div class="user-name">@Context.User.Identity.Name</div>
                    <div class="user-role">Kullanıcı</div>
                </div>
            }
        </div>

        <!-- Icerik paneli -->
        <div class="center-panel">
            @RenderBody()
        </div>

        <button id="stockaiBtn" class="stockai-fab" title="StockAI Asistanı" data-bs-toggle="modal" data-bs-target="#stockaiModal">
            <i class="fas fa-robot"></i>
        </button>
    </div>

    <div id="stockAlertToastContainer" class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1080;"></div>

    <div class="modal fade" id="stockaiModal" tabindex="-1" aria-labelledby="stockaiLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-scrollable" style="max-width: 500px;">
            <div class="modal-content" style="background: rgba(255, 255, 255, 0.8); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.3);">
                <div class="modal-header">
                    <h5 class="modal-title" id="stockaiLabel">
                        <i class="fas fa-robot me-2"></i> StockAI Asistanı
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body" id="stockaiChat" style="height: 400px; overflow-y: auto; display: flex; flex-direction: column;">
                    <div class="alert alert-info">
                        <i class="fas fa-info-circle me-2"></i>
                        Merhaba! Ben StockifyPlus'ın akıllı depo asistanı StockAI'yım. Stok soruları veya depo operasyonları hakkında sana yardımcı olabilirim.
                    </div>
                </div>
                <div class="modal-footer">
                    <div class="input-group" style="width: 100%;">
                        <input type="text" class="form-control" id="stockaiInput" placeholder="Mesajınızı yazın..." />
                        <button class="btn btn-primary" id="stockaiSend" type="button">
                            <i class="fas fa-paper-plane"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js" referrerpolicy="no-referrer"></script>
    
    <style>
        .stockai-fab {
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            color: white;
            font-size: 24px;
            cursor: pointer;
            box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
            transition: all 0.3s ease;
            z-index: 1000;
        }

        .stockai-fab:hover {
            transform: scale(1.1);
            box-shadow: 0 6px 20px rgba(102, 126, 234, 0.6);
        }

        .stockai-fab:active {
            transform: scale(0.95);
        }

        .stock-alert-toast {
            border: 1px solid rgba(255, 255, 255, 0.4);
            border-radius: 1rem;
            background: rgba(24, 27, 35, 0.78);
            backdrop-filter: blur(12px);
            color: #f8fafc;
            box-shadow: 0 14px 30px rgba(15, 23, 42, 0.35);
            min-width: 320px;
        }

        .stock-alert-toast .toast-header {
            background: transparent;
            border-bottom: 1px solid rgba(255, 255, 255, 0.16);
            color: #f8fafc;
        }

        .stock-alert-toast .btn-close {
            filter: invert(1);
        }
    </style>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const chatDiv = document.getElementById('stockaiChat');
            const input = document.getElementById('stockaiInput');
            const sendBtn = document.getElementById('stockaiSend');

            function getCsrfToken() {
                return document.querySelector('[name="__RequestVerificationToken"]')?.value || 
                       document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
            }

            async function sendMessage() {
                const message = input.value.trim();
                if (!message) return;

                // Kullanicinin yazdigi mesaji ekrana hemen basiyoruz, beklerken bosluk kalmasin.
                const userMsgDiv = document.createElement('div');
                userMsgDiv.className = 'alert alert-light text-dark my-2 ms-auto';
                userMsgDiv.style.maxWidth = '80%';
                userMsgDiv.textContent = message;
                chatDiv.appendChild(userMsgDiv);

                input.value = '';
                chatDiv.scrollTop = chatDiv.scrollHeight;

                try {
                    const csrfToken = getCsrfToken();
                    const response = await fetch('@Url.Action("Ask", "StockAI")', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': csrfToken
                        },
                        body: JSON.stringify({ message: message })
                    });

                    if (response.ok) {
                        const data = await response.json();
                        const aiBotDiv = document.createElement('div');
                        aiBotDiv.className = 'alert alert-success my-2 me-auto';
                        aiBotDiv.style.maxWidth = '80%';
                        aiBotDiv.innerHTML = '<i class="fas fa-robot me-2"></i>' + (data.response || 'Hata oluştu.');
                        chatDiv.appendChild(aiBotDiv);
                    } else {
                        let errorMessage = 'Sunucu hatası (' + response.status + ')';
                        try {
                            const errorData = await response.json();
                            if (errorData && errorData.response) {
                                errorMessage = errorData.response;
                            }
                        } catch {
                        }

                        const errorDiv = document.createElement('div');
                        errorDiv.className = 'alert alert-danger my-2 me-auto';
                        errorDiv.style.maxWidth = '80%';
                        errorDiv.textContent = 'Hata: ' + errorMessage;
                        chatDiv.appendChild(errorDiv);
                    }
                } catch (err) {
                    const errorDiv = document.createElement('div');
                    errorDiv.className = 'alert alert-danger my-2 me-auto';
                    errorDiv.style.maxWidth = '80%';
                    errorDiv.textContent = 'Bağlantı hatası: ' + err.message;
                    chatDiv.appendChild(errorDiv);
                }
                
                chatDiv.scrollTop = chatDiv.scrollHeight;
            }

            sendBtn.addEventListener('click', sendMessage);
            input.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') sendMessage();
            });
        });
    </script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            if (!@isSignedIn.ToString().ToLowerInvariant()) {
                return;
            }

            if (!window.signalR || !window.bootstrap) {
                return;
            }

            const toastContainer = document.getElementById('stockAlertToastContainer');

            function showStockAlertToast(payload) {
                if (!toastContainer) {
                    return;
                }

                const productName = payload?.productName ?? payload?.ProductName ?? 'Bilinmeyen Urun';
                const remainingStock = payload?.remainingStock ?? payload?.RemainingStock ?? '-';
                const criticalLevel = payload?.criticalLevel ?? payload?.CriticalLevel ?? '-';
                const alertTime = payload?.alertTime ?? payload?.AlertTime ?? new Date().toLocaleTimeString('tr-TR');

                const toastEl = document.createElement('div');
                toastEl.className = 'toast stock-alert-toast mb-2';
                toastEl.setAttribute('role', 'alert');
                toastEl.setAttribute('aria-live', 'assertive');
                toastEl.setAttribute('aria-atomic', 'true');

                toastEl.innerHTML = `
                    <div class="toast-header">
                        <i class="fas fa-triangle-exclamation text-warning me-2"></i>
                        <strong class="me-auto">Kritik Stok Uyarisi</strong>
                        <small>${alertTime}</small>
                        <button type="button" class="btn-close ms-2 mb-1" data-bs-dismiss="toast" aria-label="Close"></button>
                    </div>
                    <div class="toast-body">
                        <div><strong>${productName}</strong> kritik seviyeye dustu.</div>
                        <div class="small mt-1">Kalan Stok: <strong>${remainingStock}</strong> | Kritik Seviye: <strong>${criticalLevel}</strong></div>
                    </div>`;

                toastContainer.appendChild(toastEl);
                const toastInstance = new bootstrap.Toast(toastEl, { delay: 7000, autohide: true });
                toastEl.addEventListener('hidden.bs.toast', () => toastEl.remove());
                toastInstance.show();
            }

            const connection = new signalR.HubConnectionBuilder()
                .withUrl('/hubs/notification')
                .withAutomaticReconnect()
                .build();

            connection.on('ReceiveStockAlert', function (payload) {
                if (!@isPushEnabled.ToString().ToLowerInvariant()) {
                    return;
                }
                showStockAlertToast(payload);
            });

            async function startConnection() {
                try {
                    await connection.start();
                } catch {
                    setTimeout(startConnection, 5000);
                }
            }

            startConnection();
        });
    </script>
    
    @RenderSection("Scripts", required: false)
</body>
</html>



