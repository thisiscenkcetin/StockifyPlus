<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - StockifyPlus</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />

    <style>
        :root {
            --auth-primary: #1e88e5;
            --auth-secondary: #0ea5e9;
            --auth-bg-1: #e6edf5;
            --auth-bg-2: #f4f7fb;
            --auth-card: rgba(255, 255, 255, 0.86);
            --auth-border: rgba(255, 255, 255, 0.55);
            --auth-shadow: 0 18px 45px rgba(15, 23, 42, 0.16);
        }

        html, body {
            min-height: 100%;
        }

        body {
            margin: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            color: #1f2937;
            background: radial-gradient(circle at 20% 10%, #eef4fb 0%, transparent 42%),
                        radial-gradient(circle at 80% 90%, #dfeaf8 0%, transparent 35%),
                        linear-gradient(135deg, var(--auth-bg-1) 0%, var(--auth-bg-2) 100%);
            display: grid;
            place-items: center;
            padding: 1.5rem;
        }

        .auth-shell {
            width: 100%;
            max-width: 560px;
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .brand-wrap {
            text-align: center;
            margin-bottom: 0.25rem;
        }

        .brand-logo {
            max-height: 54px;
            width: auto;
            object-fit: contain;
            margin-bottom: 0.45rem;
        }

        .brand-subtitle {
            margin: 0;
            color: #667085;
            letter-spacing: 0.3px;
            font-weight: 500;
        }

        .auth-card {
            border: 1px solid var(--auth-border);
            border-radius: 1.3rem;
            background: var(--auth-card);
            backdrop-filter: blur(10px);
            box-shadow: var(--auth-shadow);
            overflow: hidden;
        }

        .auth-card-header {
            background: linear-gradient(120deg, var(--auth-primary), var(--auth-secondary));
            color: white;
            text-align: center;
            font-weight: 700;
            letter-spacing: 0.2px;
            padding: 0.85rem 1rem;
            font-size: 1.1rem;
        }

        .auth-card-body {
            padding: 1.35rem;
        }

        .auth-input-group .input-group-text {
            border-radius: 0.8rem 0 0 0.8rem;
            background: #f8fafc;
            border-color: #dbe4ee;
        }

        .auth-input-group .form-control {
            border-radius: 0 0.8rem 0.8rem 0;
            border-color: #dbe4ee;
            height: 2.8rem;
        }

        .auth-input-group .form-control:focus {
            box-shadow: 0 0 0 0.2rem rgba(30, 136, 229, 0.14);
            border-color: #9ac5f1;
        }

        .auth-divider {
            margin: 1.2rem 0;
            border-color: #d7dde6;
        }

        .demo-box {
            border: 1px solid rgba(14, 165, 233, 0.25);
            background: rgba(186, 230, 253, 0.38);
            border-radius: 1rem;
            padding: 0.95rem 1rem;
            color: #0f4d64;
        }

        @@media (max-width: 576px) {
            .auth-card-body {
                padding: 1.1rem;
            }

            .auth-card-header {
                font-size: 1rem;
            }
        }
    </style>
</head>
<body>
    <main class="auth-shell" role="main">
        <div class="brand-wrap">
            <img src="~/images/stockify-logo.png" alt="StockifyPlus" class="brand-logo" />
            <p class="brand-subtitle">Akıllı Depo Sistemi</p>
        </div>

        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
