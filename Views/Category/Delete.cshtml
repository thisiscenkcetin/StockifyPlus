@{
    var category = ViewData.Model as StockifyPlus.Models.Category;
    ViewBag.Title = "Kategoriyi Sil";
}

<div class="row">
    <div class="col-md-6 offset-md-3">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0">
                    <i class="fas fa-trash"></i> Kategoriyi Sil
                </h5>
            </div>
            <div class="card-body">
                <div class="alert alert-warning">
                    <i class="fas fa-exclamation-triangle"></i> 
                    <strong>Dikkat!</strong> Bu işlem geri alınamaz. Kategori pasif duruma geçecektir.
                </div>
                
                <p>Şu kategorinin silinmesini onaylıyor musunuz?</p>
                
                <div class="card bg-light mb-3">
                    <div class="card-body">
                        <p class="mb-1"><strong>Adı:</strong> @category.Name</p>
                        <p class="mb-1"><strong>Açıklama:</strong> @(string.IsNullOrEmpty(category.Description) ? "-" : category.Description)</p>
                        <p class="mb-0"><strong>İçinde ürün:</strong> @category.Products.Count adet</p>
                    </div>
                </div>
                
                <form method="post" asp-action="Delete">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@category.Id">
                    
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger btn-custom">
                            <i class="fas fa-trash"></i> Evet, Sil
                        </button>
                        <a href="@Url.Action("Index", "Category")" class="btn btn-secondary btn-custom">
                            <i class="fas fa-times"></i> İptal
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
