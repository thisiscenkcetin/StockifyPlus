@{
    ViewBag.Title = "Şifre Değiştir";
}

<div class="row">
    <div class="col-md-6 offset-md-3">
        <div class="card">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0">
                    <i class="fas fa-key"></i> Şifre Değiştir
                </h5>
            </div>
            <div class="card-body">
                <form method="post" asp-action="ChangePassword">
                    @Html.AntiForgeryToken()
                    
                    <div class="mb-3">
                        <label for="oldPassword" class="form-label">Eski Şifre <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-lock"></i></span>
                            <input type="password" class="form-control" id="oldPassword" name="oldPassword" 
                                   required placeholder="Eski şifreniz">
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label for="newPassword" class="form-label">Yeni Şifre <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-lock"></i></span>
                            <input type="password" class="form-control" id="newPassword" name="newPassword" 
                                   required placeholder="Yeni şifreniz (en az 8 karakter)">
                        </div>
                        <small class="form-text text-muted">
                            Gereksinimler: En az 8 karakter, büyük harf, küçük harf, rakam
                        </small>
                    </div>
                    
                    <div class="mb-3">
                        <label for="confirmPassword" class="form-label">Yeni Şifre Tekrarı <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-lock"></i></span>
                            <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" 
                                   required placeholder="Yeni şifrenizi tekrarlayın">
                        </div>
                    </div>
                    
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            @foreach (var modelState in ViewData.ModelState.Values)
                            {
                                @foreach (var error in modelState.Errors)
                                {
                                    <div>@error.ErrorMessage</div>
                                }
                            }
                        </div>
                    }
                    
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning btn-custom">
                            <i class="fas fa-save"></i> Şifre Değiştir
                        </button>
                        <a href="@Url.Action("Profile", "Account")" class="btn btn-secondary btn-custom">
                            <i class="fas fa-times"></i> İptal
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
