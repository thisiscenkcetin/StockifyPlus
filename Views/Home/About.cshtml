@{
    ViewBag.Title = "Hakkında";
}

<div class="row">
    <div class="col-md-8 offset-md-2">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">
                    <i class="fas fa-info-circle"></i> StockifyPlus Hakkında
                </h5>
            </div>
            <div class="card-body">
                <h6>Sistem Amacı</h6>
                <p>
                    StockifyPlus, işletmelerin ve depoların stok yönetimi işlemlerini elektronik ortamda 
                    gerçekleştirmek için geliştirilmiş modern bir web tabanlı uygulamadır.
                </p>
                
                <h6>Temel Özellikler</h6>
                <ul>
                    <li>Ürün ve kategori yönetimi</li>
                    <li>Gerçek zamanlı stok takibi</li>
                    <li>Stok giriş, çıkış, transfer ve ayarlama işlemleri</li>
                    <li>Düşük stok uyarıları</li>
                    <li>Stok hareketi raporları</li>
                    <li>Kullanıcı yönetimi ve rol bazlı erişim</li>
                    <li>Dashboard ve istatistikler</li>
                </ul>
                
                <h6>Teknoloji Stack</h6>
                <div class="table-responsive">
                    <table class="table table-sm">
                        <tr>
                            <td><strong>Backend Framework</strong></td>
                            <td>ASP.NET Core MVC 8.0</td>
                        </tr>
                        <tr>
                            <td><strong>Veri Tabanı</strong></td>
                            <td>Microsoft SQL Server</td>
                        </tr>
                        <tr>
                            <td><strong>ORM</strong></td>
                            <td>Entity Framework Core</td>
                        </tr>
                        <tr>
                            <td><strong>Frontend Framework</strong></td>
                            <td>Bootstrap 5</td>
                        </tr>
                        <tr>
                            <td><strong>Grafikler</strong></td>
                            <td>Chart.js</td>
                        </tr>
                        <tr>
                            <td><strong>İkonlar</strong></td>
                            <td>Font Awesome 6.4</td>
                        </tr>
                    </table>
                </div>
                
                <h6>Tasarım Desenleri</h6>
                <ul>
                    <li>Repository Pattern - Veri erişim katmanının soyutlanması</li>
                    <li>Unit of Work Pattern - Transaction yönetimi</li>
                    <li>Dependency Injection - Bağımlılık enjeksiyonu</li>
                    <li>N-Tier Architecture - Katmalı mimari</li>
                </ul>
                
                <hr>
                
                <p class="text-muted small">
                    <strong>Versiyon:</strong> 1.0.0<br>
                    <strong>Son Güncelleme:</strong> Haziran 2024<br>
                    <strong>Kuruluş:</strong> Trakya Üniversitesi
                </p>
            </div>
        </div>
    </div>
</div>
