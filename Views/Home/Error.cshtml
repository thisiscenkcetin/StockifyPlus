@{
    ViewBag.Title = "Hata";
}

<div class="row">
    <div class="col-md-6 offset-md-3 mt-5">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white text-center">
                <h3 class="mb-0">
                    <i class="fas fa-exclamation-triangle"></i> Hata
                </h3>
            </div>
            <div class="card-body text-center">
                <h2 class="display-4 text-danger">500</h2>
                <p class="lead">Sunucu Hatası</p>
                <p class="text-muted">
                    Beklenmedik bir hata oluştu. Lütfen daha sonra tekrar deneyiniz.
                </p>
                <a href="@Url.Action("Index", "Home")" class="btn btn-primary btn-custom">
                    <i class="fas fa-home"></i> Ana Sayfaya Dön
                </a>
            </div>
        </div>
    </div>
</div>
